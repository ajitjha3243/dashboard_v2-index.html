    function renderScriptDash() {
        const dashScriptSelect = document.getElementById('dash-script');
        const dashYearSelect = document.getElementById('dash-year');
        const dataContainer = document.getElementById('script-dash-data');
        
        const selectedScripts = Array.from(dashScriptSelect.selectedOptions).map(o => o.value);
        const selectedYears = Array.from(dashYearSelect.selectedOptions).map(o => o.value);

        if (selectedScripts.length === 0) { dataContainer.style.display = 'none'; return; } 
        else { dataContainer.style.display = 'block'; }

        let inventory = {}; let monthlyPnL = {}; let totalPnL = 0;
        let sortedTxs = [...currentTxs].sort((a,b) => new Date(a.date) - new Date(b.date));

        sortedTxs.forEach(tx => {
            if (!selectedScripts.includes(tx.symbol)) return;
            let b = tx.broker || 'N/A'; let s = tx.symbol; let key = `${s}::${b}`;
            let dateObj = new Date(tx.date); let year = tx.date.substring(0, 4);
            let monthKey = `${year}-${(dateObj.getMonth()+1).toString().padStart(2, '0')}`;

            if (!inventory[key]) inventory[key] = { symbol: s, broker: b, qty: 0, cost: 0 };
            if (!monthlyPnL[monthKey]) monthlyPnL[monthKey] = 0;

            if (tx.txType === 'Purchase') {
                inventory[key].qty += tx.qty; inventory[key].cost += tx.total;
            } else if (tx.txType === 'Sale') {
                let avgCost = inventory[key].qty > 0 ? (inventory[key].cost / inventory[key].qty) : 0;
                let cogs = avgCost * tx.qty;
                let tradePnL = tx.total - cogs;
                inventory[key].qty -= tx.qty; inventory[key].cost -= cogs;
                monthlyPnL[monthKey] += tradePnL;
            }
        });

        const holdingsBody = document.getElementById('dash-holdings-body');
        holdingsBody.innerHTML = '';
        Object.keys(inventory).sort().forEach(key => {
            let item = inventory[key];
            if (item.qty > 0.0001) { holdingsBody.innerHTML += `<tr><td><strong>${item.symbol}</strong></td><td>${item.broker}</td><td>${item.qty.toFixed(4)}</td><td>${(item.cost/item.qty).toFixed(2)}</td><td>${item.cost.toFixed(2)}</td></tr>`; }
        });
        if(holdingsBody.innerHTML === '') holdingsBody.innerHTML = `<tr><td colspan="5" style="text-align:center; color:#666; padding: 15px;">No current holdings</td></tr>`;

        const pnlBody = document.getElementById('dash-pnl-body');
        pnlBody.innerHTML = '';
        let keysToRender = Object.keys(monthlyPnL).sort().reverse();
        if (selectedYears.length > 0) keysToRender = keysToRender.filter(m => selectedYears.includes(m.substring(0, 4)));

        keysToRender.forEach(m => {
            let p = monthlyPnL[m]; totalPnL += p;
            if (p !== 0) { let c = p > 0 ? 'pnl-positive' : 'pnl-negative'; pnlBody.innerHTML += `<tr><td><strong>${m}</strong></td><td class="${c}">${p>0?'+':''}${p.toFixed(2)}</td></tr>`; }
        });

        const totalEl = document.getElementById('dash-pnl-total');
        totalEl.innerText = (totalPnL > 0 ? '+' : '') + totalPnL.toFixed(2);
        totalEl.className = totalPnL >= 0 ? 'pnl-positive' : 'pnl-negative';
    }

    function renderApp() {
        populateFilterDropdowns();

        const ledgerBody = document.getElementById('ledger-body'); const holdingsBody = document.getElementById('holdings-body'); const brokerInvestmentBody = document.getElementById('broker-investment-body'); const brokerLedgerBody = document.getElementById('broker-ledger-body'); const pnlBody = document.getElementById('pnl-body'); const brokerPnlBody = document.getElementById('broker-pnl-body');
        ledgerBody.innerHTML = ''; holdingsBody.innerHTML = ''; brokerInvestmentBody.innerHTML = ''; brokerLedgerBody.innerHTML = ''; pnlBody.innerHTML = ''; brokerPnlBody.innerHTML = '';
        
        let totalEquity = 0; let totalMF = 0; let totalCash = 0;
        let inventory = {}; let brokerPnLMap = {}; let brokerInvestmentMap = {}; let brokerLedgerMap = {}; let overallPnL = 0;
        let hierarchicalPnL = {}; 
        
        function addHierarchical(dateStr, symbol, amount) {
            let d = new Date(dateStr);
            let year = d.getFullYear(); let month = d.getMonth() + 1; let day = d.getDate();
            let fy = month >= 4 ? `${year}-${(year+1).toString().slice(2)}` : `${year-1}-${year.toString().slice(2)}`;
            let monthStr = month.toString().padStart(2, '0');
            let dayStr = day.toString().padStart(2, '0');

            if (!hierarchicalPnL[fy]) hierarchicalPnL[fy] = { pnl: 0, months: {} };
            if (!hierarchicalPnL[fy].months[monthStr]) hierarchicalPnL[fy].months[monthStr] = { pnl: 0, days: {} };
            if (!hierarchicalPnL[fy].months[monthStr].days[dayStr]) hierarchicalPnL[fy].months[monthStr].days[dayStr] = { pnl: 0, scripts: {} };
            if (!hierarchicalPnL[fy].months[monthStr].days[dayStr].scripts[symbol]) hierarchicalPnL[fy].months[monthStr].days[dayStr].scripts[symbol] = 0;

            hierarchicalPnL[fy].pnl += amount;
            hierarchicalPnL[fy].months[monthStr].pnl += amount;
            hierarchicalPnL[fy].months[monthStr].days[dayStr].pnl += amount;
            hierarchicalPnL[fy].months[monthStr].days[dayStr].scripts[symbol] += amount;
        }
        
        let chronTxs = [...currentTxs].sort((a,b) => new Date(a.date) - new Date(b.date));

        chronTxs.forEach(tx => {
            let b = tx.broker || 'N/A'; let key = `${tx.symbol}::${b}`;
            
            if (!inventory[key]) inventory[key] = { symbol: tx.symbol, broker: b, qty: 0, cost: 0, type: tx.assetClass, pnl: 0 };
            if (!brokerLedgerMap[b]) brokerLedgerMap[b] = 0;
            
            if (tx.txType === 'Purchase') { 
                inventory[key].qty += tx.qty; inventory[key].cost += tx.total; brokerLedgerMap[b] -= tx.total; 
            } 
            else if (tx.txType === 'Sale') {
                let avgCost = inventory[key].qty > 0 ? (inventory[key].cost / inventory[key].qty) : 0;
                let cogs = avgCost * tx.qty; let tradePnL = tx.total - cogs; 
                inventory[key].pnl += tradePnL; overallPnL += tradePnL; 
                inventory[key].qty -= tx.qty; inventory[key].cost -= cogs; brokerLedgerMap[b] += tx.total; 
                addHierarchical(tx.date, tx.symbol, tradePnL); 
            } 
            else if (tx.txType === 'Expense') { 
                overallPnL -= tx.total; inventory[key].pnl -= tx.total; brokerLedgerMap[b] -= tx.total; 
                addHierarchical(tx.date, tx.symbol, -tx.total); 
            } 
            else if (tx.txType === 'Income') { 
                overallPnL += tx.total; inventory[key].pnl += tx.total; brokerLedgerMap[b] += tx.total; 
                addHierarchical(tx.date, tx.symbol, tx.total); 
            } 
            else if (tx.txType === 'Cash Addition') { brokerLedgerMap[b] += tx.total; } 
            else if (tx.txType === 'Cash Withdrawal') { brokerLedgerMap[b] -= tx.total; }
        });

        const rBroker = document.getElementById('report-filter-broker').value; 
        const rAsset = document.getElementById('report-filter-asset').value;

        Object.keys(inventory).sort().forEach(key => {
            let item = inventory[key];
            if (rAsset !== 'All' && item.type !== rAsset) return;
            if (rBroker !== 'All' && item.broker !== rBroker) return;
            if (!brokerPnLMap[item.broker]) brokerPnLMap[item.broker] = 0;
            brokerPnLMap[item.broker] += item.pnl;

            if (item.qty > 0.0001) { 
                if (item.type === 'Equity') totalEquity += item.cost;
                if (item.type === 'Mutual Fund') totalMF += item.cost;

                if (!brokerInvestmentMap[item.broker]) brokerInvestmentMap[item.broker] = 0;
                brokerInvestmentMap[item.broker] += item.cost;
                
                // Fetch cached real time prices if loaded
                let livePrice = livePrices[item.symbol] || null;
                let currentValStr = "-";
                let unrealizedPnLStr = "-";
                let pnlStyleClass = "pnl-neutral";
                
                if(livePrice) {
                    let curValue = item.qty * livePrice;
                    let unRealizedPnL = curValue - item.cost;
                    currentValStr = curValue.toFixed(2);
                    unrealizedPnLStr = (unRealizedPnL > 0 ? "+" : "") + unRealizedPnL.toFixed(2);
                    pnlStyleClass = unRealizedPnL > 0 ? "pnl-positive" : (unRealizedPnL < 0 ? "pnl-negative" : "pnl-neutral");
                }

                holdingsBody.innerHTML += `<tr>
                    <td><strong>${item.symbol}</strong></td>
                    <td>${item.broker}</td>
                    <td>${item.type}</td>
                    <td>${item.qty.toFixed(4)}</td>
                    <td>${(item.cost/item.qty).toFixed(2)}</td>
                    <td>${item.cost.toFixed(2)}</td>
                    <td style="background: #f0fdf4; font-weight:bold;">${livePrice ? livePrice.toFixed(2) : 'Click Fetch'}</td>
                    <td style="background: #f0fdf4;">${currentValStr}</td>
                    <td style="background: #f0fdf4;" class="${pnlStyleClass}">${unrealizedPnLStr}</td>
                </tr>`;
            }
            if (item.pnl !== 0) { let c = item.pnl > 0 ? 'pnl-positive' : (item.pnl < 0 ? 'pnl-negative' : 'pnl-neutral'); pnlBody.innerHTML += `<tr><td><strong>${item.symbol}</strong></td><td>${item.broker}</td><td>${item.type}</td><td class="${c}">${item.pnl>0?'+':''}${item.pnl.toFixed(2)}</td></tr>`; }
        });

        Object.keys(brokerInvestmentMap).sort().forEach(b => brokerInvestmentBody.innerHTML += `<tr><td><strong>${b}</strong></td><td>${brokerInvestmentMap[b].toFixed(2)}</td></tr>`);
        Object.keys(brokerLedgerMap).sort().forEach(b => { 
            let bal = brokerLedgerMap[b]; totalCash += bal;
            let c = bal > 0 ? 'pnl-positive' : (bal < 0 ? 'pnl-negative' : 'pnl-neutral'); 
            brokerLedgerBody.innerHTML += `<tr><td><strong>${b}</strong></td><td class="${c}">${bal > 0 ? '+' : ''}${bal.toFixed(2)}</td></tr>`; 
        });
        Object.keys(brokerPnLMap).sort().forEach(b => { let p = brokerPnLMap[b]; if (p !== 0) brokerPnlBody.innerHTML += `<tr><td><strong>${b}</strong></td><td class="${p>0?'pnl-positive':'pnl-negative'}">${p>0?'+':''}${p.toFixed(2)}</td></tr>`; });

        // --- RENDER HIERARCHICAL TREE HTML ---
        let treeHtml = '';
        const monthNames = ["", "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

        Object.keys(hierarchicalPnL).sort().reverse().forEach(fy => {
            let fyData = hierarchicalPnL[fy];
            if (fyData.pnl === 0) return; 
            let fyClass = fyData.pnl >= 0 ? 'pnl-positive' : 'pnl-negative';
            
            treeHtml += `<div class="tree-node">
                <div class="tree-header" onclick="this.parentElement.classList.toggle('active')">
                    <span><span class="tree-arrow">▶</span> FY ${fy}</span>
                    <span class="${fyClass}">${fyData.pnl>0?'+':''}${fyData.pnl.toFixed(2)}</span>
                </div>
                <div class="tree-children">`;
            
            Object.keys(fyData.months).sort().reverse().forEach(mStr => {
                let mData = fyData.months[mStr];
                if (mData.pnl === 0) return;
                let mClass = mData.pnl >= 0 ? 'pnl-positive' : 'pnl-negative';
                
                treeHtml += `<div class="tree-node">
                    <div class="tree-header" onclick="this.parentElement.classList.toggle('active')">
                        <span><span class="tree-arrow">▶</span> ${monthNames[parseInt(mStr)]}</span>
                        <span class="${mClass}">${mData.pnl>0?'+':''}${mData.pnl.toFixed(2)}</span>
                    </div>
                    <div class="tree-children">`;
                
                Object.keys(mData.days).sort().reverse().forEach(dStr => {
                    let dData = mData.days[dStr];
                    if (dData.pnl === 0) return;
                    let dClass = dData.pnl >= 0 ? 'pnl-positive' : 'pnl-negative';
                    
                    treeHtml += `<div class="tree-node">
                        <div class="tree-header" onclick="this.parentElement.classList.toggle('active')">
                            <span><span class="tree-arrow">▶</span> ${dStr} ${monthNames[parseInt(mStr)].slice(0,3)}</span>
                            <span class="${dClass}">${dData.pnl>0?'+':''}${dData.pnl.toFixed(2)}</span>
                        </div>
                        <div class="tree-children">`;
                    
                    Object.keys(dData.scripts).sort().forEach(script => {
                        let sPnL = dData.scripts[script];
                        if(sPnL !== 0) {
                            let sClass = sPnL > 0 ? 'pnl-positive' : 'pnl-negative';
                            treeHtml += `<div class="tree-leaf">
                                <span>${script}</span>
                                <span class="${sClass}">${sPnL>0?'+':''}${sPnL.toFixed(2)}</span>
                            </div>`;
                        }
                    });
                    treeHtml += `</div></div>`;
                });
                treeHtml += `</div></div>`;
            });
            treeHtml += `</div></div>`;
        });
        
        if(treeHtml === '') treeHtml = `<div style="padding: 15px; color: #64748b; text-align: center;">No realized P&L to display.</div>`;
        document.getElementById('hierarchical-pnl-body').innerHTML = treeHtml;

        document.getElementById('equity-investment').innerText = totalEquity.toFixed(2);
        document.getElementById('mf-investment').innerText = totalMF.toFixed(2);
        document.getElementById('cash-balance').innerText = totalCash.toFixed(2);
        let pnlEl = document.getElementById('realized-pnl');
        pnlEl.innerText = (overallPnL > 0 ? '+' : '') + overallPnL.toFixed(2);
        pnlEl.className = overallPnL >= 0 ? 'pnl-positive' : 'pnl-negative';

        renderScriptDash();

        // --- LEDGER FILTER ENGINE ---
        ['date', 'broker', 'assetClass', 'txType', 'symbol', 'remark', 'qty', 'price', 'total'].forEach(col => {
            const el = document.getElementById(`sort-${col}`);
            if(el) el.innerText = (sortCol === col) ? (sortDesc ? ' ↓' : ' ↑') : '';
        });

        const searchText = document.getElementById('ledger-search') ? document.getElementById('ledger-search').value.toLowerCase().trim() : '';
        const fColDate = document.getElementById('flt-col-date').value.toLowerCase().trim();
        const fColBroker = document.getElementById('flt-col-broker').value.toLowerCase().trim();
        const fColAsset = document.getElementById('flt-col-asset').value.toLowerCase().trim();
        const fColType = document.getElementById('flt-col-type').value.toLowerCase().trim();
        const fColSymbol = document.getElementById('flt-col-symbol').value.toLowerCase().trim();
        const fColRemark = document.getElementById('flt-col-remark').value.toLowerCase().trim();

        let dynamicTxs = [...currentTxs].filter(tx => {
            let match = true;
            if(fColDate && !(tx.date || '').toLowerCase().includes(fColDate)) match = false;
            if(fColBroker && !(tx.broker || '').toLowerCase().includes(fColBroker)) match = false;
            if(fColAsset && !(tx.assetClass || '').toLowerCase().includes(fColAsset)) match = false;
            if(fColType && !(tx.txType || '').toLowerCase().includes(fColType)) match = false;
            if(fColSymbol && !(tx.symbol || '').toLowerCase().includes(fColSymbol)) match = false;
            if(fColRemark && !(tx.remark || '').toLowerCase().includes(fColRemark)) match = false;
            
            if(searchText) {
                const searchMatch = 
                    (tx.symbol || '').toLowerCase().includes(searchText) || 
                    (tx.broker || '').toLowerCase().includes(searchText) || 
                    (tx.txType || '').toLowerCase().includes(searchText) ||
                    (tx.remark || '').toLowerCase().includes(searchText);
                if(!searchMatch) match = false;
            }
            return match;
        });

        const totalDisplayEl = document.getElementById('flt-col-total-display');
        if (fColType || fColSymbol || fColRemark) {
            let sumTotal = dynamicTxs.reduce((sum, tx) => sum + tx.total, 0);
            totalDisplayEl.innerText = sumTotal.toFixed(2);
            totalDisplayEl.style.display = 'block';
        } else {
            totalDisplayEl.style.display = 'none';
        }

        dynamicTxs.sort((a, b) => {
            let valA = a[sortCol]; let valB = b[sortCol];
            if (sortCol === 'date') { valA = new Date(valA).getTime(); valB = new Date(valB).getTime(); }
            else if (['qty', 'price', 'total'].includes(sortCol)) { valA = Number(valA); valB = Number(valB); }
            else { valA = String(valA || '').toLowerCase(); valB = String(valB || '').toLowerCase(); }
            if (valA < valB) return sortDesc ? 1 : -1;
            if (valA > valB) return sortDesc ? -1 : 1;
            return 0;
        });

        const totalPages = Math.ceil(dynamicTxs.length / pageSize) || 1;
        if (currentPage > totalPages) currentPage = totalPages;
        const startIdx = (currentPage - 1) * pageSize;
        const pageTxs = dynamicTxs.slice(startIdx, startIdx + pageSize);

        pageTxs.forEach(tx => {
            let badgeClass = tx.txType.toLowerCase().replace(' ', '-');
            ledgerBody.innerHTML += `<tr>
                <td>${tx.date}</td>
                <td>${tx.broker}</td>
                <td>${tx.assetClass}</td>
                <td><span class="badge ${badgeClass}">${tx.txType}</span></td>
                <td><strong>${tx.symbol}</strong></td>
                <td>${tx.remark || '-'}</td>
                <td>${tx.qty}</td>
                <td>${tx.price.toFixed(2)}</td>
                <td><strong>${tx.total.toFixed(2)}</strong></td>
                <td><button class="btn-edit-tx" onclick="editTx('${tx.id}')">Edit</button><button class="btn-delete" onclick="deleteTx('${tx.id}')">Del</button></td>
            </tr>`;
        });
        
        if (pageTxs.length === 0) {
            ledgerBody.innerHTML = `<tr><td colspan="10" style="text-align:center; padding: 20px; color: #64748b;">No transactions found matching your search.</td></tr>`;
        }
        
        document.getElementById('page-indicator').innerText = `Page ${currentPage} of ${totalPages}`;
        document.getElementById('btn-prev').disabled = currentPage === 1;
        document.getElementById('btn-next').disabled = currentPage === totalPages;
    }
</script>
</body>
</html>
