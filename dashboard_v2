        const reader = new FileReader();
        reader.onload = async function(e) {
            try {
                const data = JSON.parse(e.target.result);
                if (data.transactions && confirm(`Proceeding will import ${data.transactions.length} transactions. Continue?`)) {
                    for(let t of data.transactions) {
                        delete t.id; t.userId = currentUser.uid; 
                        await db.collection('transactions').add(t);
                    }
                    alert("Database restored securely!"); window.location.reload(); 
                }
            } catch (err) { alert("Invalid backup file."); }
            event.target.value = ''; 
        };
        reader.readAsText(file);
    }

