    // --- LIVE MARKET DATA OVERLAY MODULE ---
    async function fetchLivePrices() {
        // Collect all unique non-CASH stock symbols currently held
        let inventorySymbols = new Set();
        currentTxs.forEach(tx => {
            if (tx.symbol && tx.symbol !== 'CASH') {
                inventorySymbols.add(tx.symbol.toUpperCase().trim());
            }
        });

        const symbolsArray = Array.from(inventorySymbols);
        if (symbolsArray.length === 0) {
            alert("No symbols available to check live prices.");
            return;
        }

        const apiKey = document.getElementById('live-api-key').value.trim();
        alert(`Fetching real-time market snapshots for ${symbolsArray.length} items...`);

        // Perform parallel async fetch targeting CORS-compliant endpoints
        // Appends market flags dynamically (.NS) for standard India setups if suffix is missing
        for (let sym of symbolsArray) {
            let apiSymbol = sym;
            if (!sym.includes('.')) {
                apiSymbol = sym + ".NS"; // Map dynamically to NSE layout
            }
            
            try {
                // Configures clean endpoint access (e.g., standard free quote tracking)
                let url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${apiSymbol}`;
                // Optional failover to public endpoints if keys are dropped
                if(apiKey) {
                    url = `https://finnhub.io/api/v1/quote?symbol=${sym}&token=${apiKey}`;
                }
                
                // Using standard open-cors client wrapper
                const res = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`);
                if (res.ok) {
                    const wrapData = await res.json();
                    const data = JSON.parse(wrapData.contents);
                    
                    let price = 0;
                    if (data.quoteResponse && data.quoteResponse.result && data.quoteResponse.result[0]) {
                        price = data.quoteResponse.result[0].regularMarketPrice;
                    } else if (data.c) {
                        price = data.c; // Finnhub output key mapping
                    }
                    
                    if (price > 0) {
                        livePrices[sym] = price;
                    }
                }
            } catch (err) {
                console.warn(`Failed fetching real time value for: ${sym}`, err);
            }
        }
        
        // Re-render dashboard components with new loaded balances
        renderApp();
    }

